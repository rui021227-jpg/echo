# ─── Supabase ────────────────────────────────────────────────────────────────
# Production project: echo v1 (ppwhyawhdsydhajkyxof, us-east-1)
# Both URLs are already set to the deployed project — copy as-is.
EXPO_PUBLIC_SUPABASE_EDGE_FUNCTION_URL=https://ppwhyawhdsydhajkyxof.supabase.co/functions/v1/weekly-reflection
EXPO_PUBLIC_SUPABASE_CLOUD_SYNC_URL=https://ppwhyawhdsydhajkyxof.supabase.co/functions/v1/cloud-sync

# ─── RevenueCat ──────────────────────────────────────────────────────────────
# Get from: app.revenuecat.com → Project → Apps → [platform] → Public API Key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=YOUR_IOS_REVENUECAT_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=YOUR_ANDROID_REVENUECAT_KEY

# ─── Sentry ──────────────────────────────────────────────────────────────────
# See docs/SENTRY_SETUP.md for the full walkthrough.
# DSN: sentry.io → Project → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=
# Org/project slugs from your Sentry URL — required to upload source maps during EAS builds
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token: sentry.io → Settings → Auth Tokens → scope: project:write
SENTRY_AUTH_TOKEN=
# Leave as-is unless you are self-hosting Sentry
SENTRY_URL=https://sentry.io/

# ─── App ─────────────────────────────────────────────────────────────────────
# Deploy privacy-policy/ to Vercel (see privacy-policy/README.md), then update this.
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://echo-privacy.vercel.app

# ─── Server-side secrets (NOT here — set in Supabase Dashboard) ──────────────
# Project Settings → Edge Functions → Secrets:
#   OPENAI_API_KEY            → weekly-reflection function (get from platform.openai.com)
#   REVENUECAT_WEBHOOK_AUTH_TOKEN → revenuecat-webhook function (any strong random string;
#                                   paste same value in RevenueCat dashboard → Webhooks)
